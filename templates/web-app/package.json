{
    "$schema": "https://www.schemastore.org/package.json",
    "name": "web-app-template",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "test": "vitest run --passWithNoTests",
        "lint": "eslint \"resources/js/**/*.{js,vue}\"",
        "lint:fix": "eslint \"resources/js/**/*.{js,vue}\" --fix",
        "format": "prettier --write \"resources/**/*.{js,vue,css}\"",
        "format:check": "prettier --check \"resources/**/*.{js,vue,css}\""
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@laravel/vite-plugin-wayfinder": "^0.1.7",
        "@tailwindcss/vite": "^4.0.0",
        "@vitejs/plugin-vue": "^6.0.4",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^9.1.2",
        "eslint-plugin-vue": "^9.33.0",
        "globals": "^15.15.0",
        "laravel-vite-plugin": "^2.0.0",
        "prettier": "^3.8.3",
        "tailwindcss": "^4.0.0",
        "vite": "^7.0.7",
        "vitest": "^4.1.5",
        "vue-eslint-parser": "^9.4.3"
    },
    "dependencies": {
        "@inertiajs/vue3": "^2.3.15",
        "vue": "^3.5.28",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-vue-next": "^0.575.0",
        "reka-ui": "^2.8.2",
        "tailwind-merge": "^3.5.0",
        "tw-animate-css": "^1.4.0"
    },
    "description": "monjizeen-dev web app template"
}
