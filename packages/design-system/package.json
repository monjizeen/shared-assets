{
  "name": "@monjizeen/design-system",
  "version": "0.1.0",
  "description": "Org design system — shadcn-vue primitives, patterns, tokens, and composables for Laravel + Inertia + Vue 3 apps",
  "type": "module",
  "license": "UNLICENSED",
  "private": true,
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": "./src/index.js",
    "./styles": "./styles/index.css",
    "./styles/*": "./styles/*",
    "./ui/*": "./src/ui/*/index.js",
    "./ui/*.vue": "./src/ui/*/*.vue",
    "./patterns/*": "./src/patterns/*",
    "./composables/*": "./src/composables/*.js",
    "./lib/*": "./src/lib/*.js",
    "./store/*": "./src/store/*.js",
    "./docs/*": "./docs/*"
  },
  "files": [
    "src",
    "styles",
    "assets",
    "docs"
  ],
  "peerDependencies": {
    "@vueuse/core": "^14.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "lucide-vue-next": "^0.575.0",
    "reka-ui": "^2.8.0",
    "tailwind-merge": "^3.0.0",
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/vue-table": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@tanstack/vue-table": "^8.21.0"
  },
  "scripts": {
    "sync": "bash scripts/sync-from-monjizeen.sh"
  }
}
